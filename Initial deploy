      ${!isBot ? `<div class="msg-avatar" style="background:rgba(0,82,255,0.15);">👤</div>` : ''}
    `;
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
  }

  let typingCounter = 0;
  function appendTyping() {
    const id = 'typing-' + (++typingCounter);
    const msgs = document.getElementById('chat-messages');
    const div = document.createElement('div');
    div.className = 'msg bot'; div.id = id;
    div.innerHTML = `<div class="msg-avatar"><img src="https://ipfs.io/ipfs/bafybeigp7fkiyidic4khmpdur5uutlnxry4rekef5myethajg2fex54jr4" onerror="this.parentElement.innerHTML='🤖'"/></div><div class="msg-bubble"><div class="typing-dots"><span></span><span></span><span></span></div></div>`;
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
    return id;
  }
  function removeTyping(id) {
    const el = document.getElementById(id);
    if (el) el.remove();
  }
