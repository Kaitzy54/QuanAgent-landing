    {type:'dim',text:'─────────────────────────────────────────'},
    {type:'info',text:'Next scan cycle in 12s...'},
  ];
  const terminalEl = document.getElementById('terminal-log');
  let logIdx = 0;
  function getTime(){const d=new Date();return String(d.getMinutes()).padStart(2,'0')+':'+String(d.getSeconds()).padStart(2,'0');}
  const cursorEl = document.createElement('div');
  cursorEl.className='log-line';
  cursorEl.innerHTML=`<span class="log-time"></span><span class="log-dim">$ agent <span class="cursor"></span></span>`;
  terminalEl.appendChild(cursorEl);
  function addLog(){
    if(logIdx>=logs.length){logIdx=0;const sep=document.createElement('div');sep.className='log-line';sep.innerHTML='<span class="log-dim">── new cycle ────────────────────────────</span>';terminalEl.appendChild(sep);}
    const log=logs[logIdx++];
    const line=document.createElement('div');
    line.className='log-line';
    line.innerHTML=`<span class="log-time">${getTime()}</span><span class="log-${log.type}">${log.text}</span>`;
    terminalEl.insertBefore(line,cursorEl);
    terminalEl.scrollTop=terminalEl.scrollHeight;
    while(terminalEl.children.length>62)terminalEl.removeChild(terminalEl.firstChild);
  }
  setTimeout(()=>setInterval(addLog,1400),800);
  setInterval(()=>{terminalEl.removeChild(cursorEl);terminalEl.appendChild(cursorEl);},1400);

  // ---- Chat widget ----
