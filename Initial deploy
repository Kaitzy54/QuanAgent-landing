    setTimeout(() => { t.style.opacity='0'; t.style.transition='opacity 0.3s'; setTimeout(()=>t.remove(),300); }, 2200);
  }

  // Scroll reveal
  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
  }, {threshold:0.1});
  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

  // ---- Terminal logs ----
  const logs = [
    {type:'info',text:'Scanning liquidity pools — filter: 1–5 ETH range...'},
    {type:'ok',text:'✓ High-Conviction Sniper armed · target identified'},
    {type:'info',text:'Loading smart-money wallet registry [312 wallets]...'},
