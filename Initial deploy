<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>QuantAGent — AI Trading Agent on Base</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:wght@300;400;500&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --base-blue: #0052FF;
      --base-blue-dim: #0041CC;
      --silver: #A8B2C0;
      --silver-light: #D4DCE8;
      --chrome: #C8D4E0;
      --bg-deep: #050810;
      --bg-card: #090E1A;
      --bg-card2: #0C1220;
      --border: rgba(168,178,192,0.12);
      --border-blue: rgba(0,82,255,0.3);
      --glow: rgba(0,82,255,0.15);
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      background: var(--bg-deep);
      color: var(--silver-light);
      font-family: 'DM Sans', sans-serif;
      overflow-x: hidden;
    }
    h1,h2,h3,h4,h5 { font-family: 'Syne', sans-serif; }
    .mono { font-family: 'DM Mono', monospace; }

    .grid-bg {
      background-image:
        linear-gradient(rgba(0,82,255,0.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,82,255,0.04) 1px, transparent 1px);
      background-size: 60px 60px;
    }

    .orb { position: absolute; border-radius: 50%; filter: blur(120px); pointer-events: none; }
    .orb-blue { background: rgba(0,82,255,0.18); }
    .orb-silver { background: rgba(168,178,192,0.08); }

    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      backdrop-filter: blur(20px);
      background: rgba(5,8,16,0.8);
      border-bottom: 1px solid var(--border);
    }

    .badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(0,82,255,0.1);
      border: 1px solid var(--border-blue);
      border-radius: 100px;
      padding: 6px 16px;
      font-size: 0.75rem;
      font-family: 'DM Mono', monospace;
      color: #5C8FFF;
      letter-spacing: 0.05em;
    }
    .badge-dot {
      width: 6px; height: 6px; border-radius: 50%;
      background: #0052FF;
      box-shadow: 0 0 8px #0052FF;
      animation: pulse-dot 1.8s infinite;
    }
    @keyframes pulse-dot { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(1.4)} }

    .grad-text {
      background: linear-gradient(135deg, #fff 0%, var(--chrome) 50%, #5C8FFF 100%);
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .btn-primary {
      background: var(--base-blue); color: #fff;
      font-family: 'Syne', sans-serif; font-weight: 600;
      letter-spacing: 0.02em; border-radius: 8px;
      padding: 14px 32px; font-size: 0.95rem;
      transition: all 0.2s;
      box-shadow: 0 0 30px rgba(0,82,255,0.35), inset 0 1px 0 rgba(255,255,255,0.1);
      border: none; cursor: pointer; text-decoration: none; display: inline-block;
    }
    .btn-primary:hover {
      background: #0041CC;
      box-shadow: 0 0 50px rgba(0,82,255,0.55), inset 0 1px 0 rgba(255,255,255,0.15);
      transform: translateY(-1px);
    }
    .btn-ghost {
      background: transparent; color: var(--silver);
      font-family: 'Syne', sans-serif; font-weight: 500;
      letter-spacing: 0.02em; border-radius: 8px;
      padding: 13px 28px; font-size: 0.95rem;
      transition: all 0.2s; border: 1px solid var(--border);
      cursor: pointer; text-decoration: none; display: inline-block;
    }
    .btn-ghost:hover { border-color: rgba(168,178,192,0.3); color: #fff; background: rgba(168,178,192,0.05); }

    .ca-box {
      display: inline-flex; align-items: center; gap: 12px;
      background: var(--bg-card2); border: 1px solid var(--border);
      border-radius: 10px; padding: 10px 18px;
    }
    .copy-btn {
      background: rgba(0,82,255,0.15); border: 1px solid var(--border-blue);
      color: #5C8FFF; border-radius: 6px; padding: 5px 14px;
      font-size: 0.75rem; font-family: 'DM Mono', monospace;
      cursor: pointer; transition: all 0.2s; white-space: nowrap;
    }
    .copy-btn:hover { background: rgba(0,82,255,0.3); color: #fff; }

    .feat-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 16px; padding: 28px;
      transition: all 0.3s; position: relative; overflow: hidden;
    }
    .feat-card::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, var(--border-blue), transparent);
      opacity: 0; transition: opacity 0.3s;
    }
    .feat-card:hover { border-color: rgba(0,82,255,0.25); transform: translateY(-3px); background: var(--bg-card2); }
    .feat-card:hover::before { opacity: 1; }
    .feat-icon {
      width: 44px; height: 44px;
      background: rgba(0,82,255,0.12); border: 1px solid var(--border-blue);
      border-radius: 10px; display: flex; align-items: center; justify-content: center;
      margin-bottom: 16px; font-size: 1.2rem;
    }

    .terminal {
      background: #020509; border: 1px solid var(--border); border-radius: 16px; overflow: hidden;
    }
    .terminal-bar {
      background: #080D18; border-bottom: 1px solid var(--border);
      padding: 12px 18px; display: flex; align-items: center; gap: 8px;
    }
    .t-dot { width:10px;height:10px;border-radius:50%; }
    .terminal-body {
      padding: 20px 24px; font-family: 'DM Mono', monospace;
      font-size: 0.78rem; height: 320px; overflow-y: auto;
    }
    .terminal-body::-webkit-scrollbar { width: 4px; }
    .terminal-body::-webkit-scrollbar-track { background: transparent; }
    .terminal-body::-webkit-scrollbar-thumb { background: rgba(0,82,255,0.3); border-radius: 4px; }

    .log-line { display: flex; gap: 12px; margin-bottom: 8px; line-height: 1.5; animation: fadein 0.4s ease; }
    @keyframes fadein { from{opacity:0;transform:translateY(4px)} to{opacity:1;transform:translateY(0)} }
    .log-time  { color: rgba(168,178,192,0.4); min-width: 54px; }
    .log-ok    { color: #22c55e; }
    .log-info  { color: #5C8FFF; }
    .log-warn  { color: #f59e0b; }
    .log-alert { color: #ef4444; }
    .log-silver{ color: var(--silver); }
    .log-dim   { color: rgba(168,178,192,0.45); }

    .cursor {
      display: inline-block; width: 7px; height: 13px;
      background: #0052FF; margin-left: 4px;
      animation: blink 1.1s infinite; vertical-align: middle;
    }
    @keyframes blink { 0%,49%{opacity:1} 50%,100%{opacity:0} }

    .stat-card {
      background: var(--bg-card); border: 1px solid var(--border);
      border-radius: 14px; padding: 24px 28px; text-align: center;
    }

    .divider {
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--border), transparent);
      margin: 0 auto; max-width: 600px;
    }

    .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    .network-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(0,82,255,0.08); border: 1px solid rgba(0,82,255,0.2);
      border-radius: 8px; padding: 8px 16px;
      font-family: 'DM Mono', monospace; font-size: 0.75rem; color: #5C8FFF;
    }
    .base-logo { width:16px;height:16px;border-radius:50%;background:linear-gradient(135deg,#0052FF,#1A6BFF); }

    footer { border-top: 1px solid var(--border); }

    @media (max-width: 768px) { .hero-title { font-size: 2.6rem !important; } }

    /* ===== TELEGRAM BUBBLE ===== */
    #tg-bubble {
      position: fixed; bottom: 100px; right: 28px; z-index: 998;
      width: 52px; height: 52px; border-radius: 50%;
      background: #229ED9;
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: all 0.2s;
      box-shadow: 0 4px 20px rgba(34,158,217,0.4);
      text-decoration: none;
    }
    #tg-bubble:hover { transform: scale(1.08); box-shadow: 0 6px 28px rgba(34,158,217,0.6); }
    #tg-bubble svg { width: 28px; height: 28px; fill: #fff; }
    #tg-tooltip {
      position: fixed; bottom: 164px; right: 28px; z-index: 997;
      background: var(--bg-card2); border: 1px solid rgba(34,158,217,0.3);
      border-radius: 10px; padding: 8px 14px;
      font-family: 'DM Mono', monospace; font-size: 0.72rem; color: var(--silver);
      white-space: nowrap; pointer-events: none;
      animation: tooltip-in 0.2s ease;
    }
    @keyframes tooltip-in { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }

    /* ===== AI CHAT WIDGET ===== */
    #chat-bubble {
      position: fixed; bottom: 28px; right: 28px; z-index: 999;
      width: 52px; height: 52px; border-radius: 50%;
      background: var(--base-blue);
      display: flex; align-items: center; justify-content: center;
      cursor: pointer; transition: all 0.2s;
      box-shadow: 0 4px 24px rgba(0,82,255,0.5);
      border: none;
    }
    #chat-bubble:hover { transform: scale(1.08); box-shadow: 0 6px 32px rgba(0,82,255,0.7); }
    #chat-bubble svg { width: 24px; height: 24px; }

    #chat-window {
      position: fixed; bottom: 92px; right: 28px; z-index: 999;
      width: 360px; height: 480px;
      background: var(--bg-card);
      border: 1px solid var(--border-blue);
      border-radius: 20px;
      display: flex; flex-direction: column;
      box-shadow: 0 20px 60px rgba(0,0,0,0.6), 0 0 40px rgba(0,82,255,0.1);
      transform-origin: bottom right;
      transition: all 0.25s cubic-bezier(0.34,1.56,0.64,1);
      transform: scale(0); opacity: 0; pointer-events: none;
    }
    #chat-window.open { transform: scale(1); opacity: 1; pointer-events: all; }

    .chat-header {
      background: var(--bg-card2);
      border-bottom: 1px solid var(--border);
      border-radius: 20px 20px 0 0;
      padding: 14px 18px;
      display: flex; align-items: center; gap: 10px;
    }
    .chat-avatar {
      width: 34px; height: 34px; border-radius: 50%;
      background: rgba(0,82,255,0.15);
      border: 1px solid var(--border-blue);
      display: flex; align-items: center; justify-content: center;
      overflow: hidden;
    }
    .chat-avatar img { width: 26px; height: 26px; object-fit: contain; }
    .chat-title { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 0.9rem; color: #fff; }
    .chat-sub { font-family: 'DM Mono', monospace; font-size: 0.65rem; color: #22c55e; }
    .chat-close {
      margin-left: auto; background: none; border: none;
      color: var(--silver); cursor: pointer; font-size: 1.2rem;
      line-height: 1; padding: 4px; border-radius: 4px;
      transition: color 0.15s;
    }
    .chat-close:hover { color: #fff; }

    .chat-messages {
      flex: 1; overflow-y: auto; padding: 16px;
      display: flex; flex-direction: column; gap: 10px;
      scroll-behavior: smooth;
    }
    .chat-messages::-webkit-scrollbar { width: 3px; }
    .chat-messages::-webkit-scrollbar-thumb { background: rgba(0,82,255,0.3); border-radius: 4px; }

    .msg { display: flex; gap: 8px; align-items: flex-end; }
    .msg.user { flex-direction: row-reverse; }
    .msg-bubble {
      max-width: 80%; padding: 10px 14px;
      border-radius: 16px; font-size: 0.82rem;
      line-height: 1.5;
    }
    .msg.bot .msg-bubble {
      background: var(--bg-card2); border: 1px solid var(--border);
      color: var(--silver-light); border-bottom-left-radius: 4px;
    }
    .msg.user .msg-bubble {
      background: var(--base-blue); color: #fff;
      border-bottom-right-radius: 4px;
    }
    .msg-avatar {
      width: 26px; height: 26px; border-radius: 50%;
      background: rgba(0,82,255,0.15); border: 1px solid var(--border-blue);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.65rem; flex-shrink: 0; overflow: hidden;
    }
    .msg-avatar img { width: 20px; height: 20px; object-fit: contain; }

    .typing-dots { display: flex; gap: 4px; padding: 4px 2px; }
    .typing-dots span {
      width: 6px; height: 6px; border-radius: 50%;
      background: var(--silver); display: block;
      animation: typing 1.2s infinite;
    }
    .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
    .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
    @keyframes typing { 0%,60%,100%{transform:translateY(0);opacity:0.4} 30%{transform:translateY(-6px);opacity:1} }

    .chat-quick-replies {
      display: flex; gap: 6px; flex-wrap: wrap; padding: 0 16px 10px;
    }
    .qr-btn {
      background: rgba(0,82,255,0.1); border: 1px solid var(--border-blue);
      color: #5C8FFF; border-radius: 20px;
      padding: 5px 12px; font-size: 0.72rem;
      font-family: 'DM Mono', monospace;
      cursor: pointer; transition: all 0.15s; white-space: nowrap;
    }
    .qr-btn:hover { background: rgba(0,82,255,0.25); color: #fff; }

    .chat-input-row {
      border-top: 1px solid var(--border);
      padding: 12px 14px;
      display: flex; gap: 8px; align-items: center;
      border-radius: 0 0 20px 20px;
    }
    .chat-input {
      flex: 1; background: var(--bg-card2);
      border: 1px solid var(--border); border-radius: 10px;
      color: #fff; font-size: 0.82rem; font-family: 'DM Sans', sans-serif;
      padding: 9px 14px; outline: none; transition: border-color 0.15s;
    }
    .chat-input::placeholder { color: rgba(168,178,192,0.4); }
    .chat-input:focus { border-color: var(--border-blue); }
    .chat-send {
      width: 36px; height: 36px; border-radius: 8px;
      background: var(--base-blue); border: none;
      cursor: pointer; display: flex; align-items: center; justify-content: center;
      transition: all 0.15s; flex-shrink: 0;
    }
    .chat-send:hover { background: #0041CC; transform: scale(1.05); }
    .chat-send svg { width: 16px; height: 16px; fill: #fff; }

    @media(max-width:480px){
      #chat-window { width: calc(100vw - 20px); right: 10px; bottom: 80px; }
    }
  </style>
</head>
