    {type:'info',text:'Subscribing to supply-burn event streams...'},
    {type:'ok',text:'✓ Auto-Burn Monitor live on 847 contracts'},
    {type:'info',text:'Indexing Twitter influencer accounts [top 200]...'},
    {type:'ok',text:'✓ Viral Detector ready · threshold: 3σ spike'},
    {type:'info',text:'Initializing volume radar · baseline established...'},
    {type:'warn',text:'⚠ Volume anomaly: TOKEN_XYZ +347% in 4min'},
